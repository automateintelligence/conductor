#!/usr/bin/env bash
set -euo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
# HERE = the plugin dir (tool code only). The PROJECT owns run state + the done-gate:
# $CONDUCTOR_HOME, else the git repo of the current directory, else cwd. Resolve once and
# export it so assertions/run.py and conductor.freeze agree with this and with each other.
PROJECT="${CONDUCTOR_HOME:-$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || pwd)}"
export CONDUCTOR_HOME="$PROJECT"
case "${1:-}" in
  assert) shift; [ "${1:-}" = "run" ] || { echo "usage: conductor assert run [--level spec|phase|task]" >&2; exit 64; }; shift; exec python3 "$HERE/assertions/run.py" "$@" ;;
  ledger) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m ledger "$@" ;;
  goal)
    shift
    GOAL_FILE="$PROJECT/.conductor/goal.md"
    case "${1:-}" in
      set)
        shift
        mkdir -p "$PROJECT/.conductor"
        printf '%s\n' "$*" > "$GOAL_FILE"
        ;;
      get)
        if [ ! -f "$GOAL_FILE" ]; then
          echo "no goal set" >&2
          exit 1
        fi
        cat "$GOAL_FILE"
        ;;
      *) printf "usage:\n  conductor goal set <text...>\n  conductor goal get\n" >&2; exit 64 ;;
    esac
    ;;
  authority) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.authority "$@" ;;
  preflight) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.preflight "$@" ;;
  plan-lint) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.plan_lint "$@" ;;
  merge) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.merge_cmd "$@" ;;
  merge-gate) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.merge_gate "$@" ;;
  run-packet) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.run_packet "$@" ;;
  resume-script) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.resume_script "$@" ;;
  driver) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.driver "$@" ;;
  remote) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.remote "$@" ;;
  run-branch) shift; [ "${1:-}" = "name" ] || { echo "usage: conductor run-branch name <spec.md>" >&2; exit 64; }; shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.branches name "$@" ;;
  default-branch) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.branches default "$@" ;;
  gate-dir) shift
    # The run's per-spec done-gate dir (assertions/<slug>), single-sourced with the run
    # branch: <slug> = `run-branch name` minus the conductor/run- prefix, so the gate dir
    # and the run branch never diverge. Setup writes the manifest+tests there instead of the
    # shared flat assertions/ slot. $CONDUCTOR_GATE_DIR overrides outright — MUST match
    # paths.gate_dir()/setup_gate_dir(), or setup would write one dir and the gate commands
    # read another.
    # Mirror paths.gate_dir() precedence exactly: $CONDUCTOR_GATE_DIR > $CONDUCTOR_GATE_SLUG >
    # the spec-derived slug. Diverging here would write the manifest to one dir while
    # lint/freeze/run read another.
    # Print the PROJECT-ROOTED path paths.gate_dir() resolves (absolute, under $PROJECT =
    # $CONDUCTOR_HOME/git-root), NOT a cwd-relative one — the CLI may be invoked from outside
    # the project root, and a cwd-relative path would write the manifest somewhere the gate
    # commands never read.
    [ -n "${1:-}" ] || { echo "usage: conductor gate-dir <spec.md>" >&2; exit 64; }
    if [ -n "${CONDUCTOR_GATE_DIR:-}" ]; then
      printf '%s\n' "$CONDUCTOR_GATE_DIR"
    elif [ -n "${CONDUCTOR_GATE_SLUG:-}" ]; then
      printf '%s/assertions/%s\n' "$PROJECT" "$CONDUCTOR_GATE_SLUG"
    else
      RB="$(PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" python3 -m conductor.branches name "$1")" || exit $?
      printf '%s/assertions/%s\n' "$PROJECT" "${RB#conductor/run-}"
    fi
    ;;
  gate) shift; PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m conductor.freeze "$@" ;;
  *) printf "usage:\n  conductor assert run [--level spec|phase|task]\n  conductor ledger {generate <plan.json>|convert <plan.md>|align <plan.md> [--apply]|reconcile <issue#> [--from-gate|flags]|phase-done <issue#> [--plan plan.md] [--no-gate-check]}\n  conductor plan-lint <plan.md> [--spec <spec.md>]\n  conductor authority preview <plan.md>\n  conductor goal {set <text...>|get}\n  conductor preflight\n  conductor merge <pr>            (gate + merge, refuses base=default)\n  conductor merge-gate <pr>\n  conductor run-packet <run-branch> [--base main] [--milestone TITLE]\n  conductor resume-script {write|verify} --project <root> --worktree <path> [--out <path> [--force]|--script <path>]\n  conductor resume-script {install-cron|uninstall-cron} --project <root>\n  conductor driver {install --worktree <path>|status}\n  conductor remote\n  conductor run-branch name <spec.md>\n  conductor default-branch\n  conductor gate-dir <spec.md>    (the run's per-spec gate dir: assertions/<slug>)\n  conductor gate {lint|freeze|verify}\n" >&2; exit 64 ;;
esac
