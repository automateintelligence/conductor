#!/usr/bin/env bash
set -euo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
case "${1:-}" in
  assert) shift; [ "${1:-}" = "run" ] || { echo "usage: conductor assert run [--level spec|phase|task]" >&2; exit 64; }; shift; exec python3 "$HERE/assertions/run.py" "$@" ;;
  ledger) shift; cd "$HERE" && exec python3 -m ledger "$@" ;;
  *) printf "usage:\n  conductor assert run [--level spec|phase|task]\n  conductor ledger {generate <plan.json>|convert <plan.md>|reconcile <issue#> [flags]}\n" >&2; exit 64 ;;
esac
